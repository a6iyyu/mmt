generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model lecturer {
  id                 Int              @id @default(autoincrement())
  name               String           @db.VarChar(100)
  nip                String?          @unique
  position           LecturerPosition
  field              String
  photo              String?
  email              String           @unique
  sinta              String?          @unique @db.VarChar(255)
  scholar            String?          @unique @db.VarChar(255)
  linkedin           String?          @unique
  research_interests Json?
  researches         research[]       @relation("lecturer_research")
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
}

model project {
  id                 Int               @id @default(autoincrement())
  title              String
  slug               String?           @unique
  description        String            @db.Text
  image              String
  category           String
  featured           Boolean           @default(false)
  views              Int               @default(0)
  stars              Int               @default(0)
  demo_link          String?           @unique
  code_link          String?           @unique
  publication_status PublicationStatus @default(ONGOING)
  publish_date       DateTime?
  students           student[]         @relation("student_project")
  technologies       tech[]            @relation("project_tech")
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
}

model student {
  id         Int           @id @default(autoincrement())
  name       String        @db.VarChar(100)
  nim        String?       @unique
  major      String
  focus      String?
  field      String?
  batch      Int?
  image      String?
  email      String?       @unique
  linkedin   String?       @unique
  whatsapp   String?       @unique
  github     String?       @unique
  projects   project[]     @relation("student_project")
  status     StudentStatus @default(ACTIVE)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
}

model course {
  id            Int          @id @default(autoincrement())
  title         String       @unique
  slug          String       @unique
  category      String
  level         String
  image         String
  mentor_name   String
  mentor_avatar String?
  price         String
  duration      String
  rating        Float?
  description   String?      @db.Text
  date          DateTime?
  location      String?
  quota         Int?
  availability  Availability @default(OPEN)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
}

model user {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(ADMIN)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model research {
  id           Int               @id @default(autoincrement())
  title        String
  slug         String            @unique
  description  String            @db.Text
  image        String
  link         String?           @unique
  status       PublicationStatus @default(ONGOING)
  publish_date DateTime?
  category     Category
  lecturers    lecturer[]        @relation("lecturer_research")
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
}

model certificate {
  id                 Int       @id @default(autoincrement())
  title              String
  image              String
  description        String    @db.Text
  link               String?
  tags               Json?
  certificate_number String?   @unique
  recipient_name     String?
  role               String?
  issue_date         DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
}

model tech {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  projects project[] @relation("project_tech")
}

enum Availability {
  OPEN
  FULL
  UPCOMING
}

enum Category {
  GAME_DEVELOPMENT
  UI_UX
  AR_VR
  ANIMATION
  MULTIMEDIA
  OTHERS
}

enum LecturerPosition {
  EXPERT_ASSISTANT
  ASSISTANT_PROFESSOR
  ASSOCIATE_PROFESSOR
  PROFESSOR
}

enum PublicationStatus {
  SCHEDULED
  ONGOING
  PUBLISHED
  ARCHIVED
}

enum Role {
  ADMIN
}

enum StudentStatus {
  ACTIVE
  ON_LEAVE
  GRADUATED
}